+    lines.append("")
+    lines.append("### Period coverage")
+    lines.append("")
+    lines.append("| Period | Accession (old → new) | UNKNOWN rows | UNKNOWN AUM (USD) |")
+    lines.append("|---|---|---:|---:|")
+    for period in sorted(cohort["by_period"]):
+        acc_new = ASA_ACCESSIONS[period]
+        rows = cohort["by_period"][period]["rows"]
