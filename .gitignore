# Database and raw data — too large for Git
data/13f.duckdb
data/13f.duckdb.wal

# DuckDB write-ahead logs + runtime per-pipeline lock files
data/*.lock
data/*.wal

# Generated flat closures log — rebuildable via
# `python3 scripts/hygiene/concat_closed_log.py` from docs/closures/*.md.
docs/closed-items-log.md
# sec-01-p1 hotfix: admin_sessions lives in its own DB file — bootstrapped
# on first use by scripts/admin_bp.py. Not tracked in git.
data/admin.duckdb
data/admin.duckdb.wal
data/raw/
data/extracted/
data/market/
data/nport_raw/
# DB backups (per-session parquet dumps, multi-GB)
data/backups/
# Local cache root (18 GB at session close 2026-04-13; previously only
# the adv_* subpaths were ignored, which left the root open to accidents)
data/cache/
# Large SEC reference feeds — re-downloadable; keep small CSVs tracked
data/reference/*.xml.gz

# Outputs — generated files
outputs/

# Logs
logs/

# Auto-resolve log — regenerated on each run
data/reference/auto_resolve_log.csv

# Python
__pycache__/
*.pyc
.DS_Store
*.egg-info/
.env

# Jupyter checkpoints
.ipynb_checkpoints/
data/13f_readonly.duckdb
data/13f_dera_parity.duckdb
13f_test.duckdb
13f_staging.duckdb

# React build output
web/static/dist/
# React build artifacts (also covered by web/react-app/.gitignore)
web/react-app/dist/

# TypeScript incremental build info (regenerated on every tsc)
**/*.tsbuildinfo

# Node modules
web/react-src/node_modules/

# Per-session prompts (paste-ins, not source)
PHASE*_PROMPT.md

# Local Claude harness state (per-workstation)
.claude/

# Working data CSVs — regenerate-on-demand artefacts. Reference CSVs
# live under data/reference/ and stay tracked there; anything at
# data/*.csv is a session scratch file.
data/*.csv

# L1 artefact caches — pipeline-local fetch results, re-downloadable
data/13dg_raw/
